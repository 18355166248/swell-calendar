#!/bin/sh
# pre-commit hook — 机械化执行门控
# 启用方式：git config core.hooksPath .githooks

set -e

export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:/c/Program Files/Git/usr/bin:/c/Program Files/Git/mingw64/bin:/c/Program Files/nodejs:$PATH"

run_pnpm() {
  if command -v pnpm >/dev/null 2>&1; then
    pnpm "$@"
  elif command -v corepack >/dev/null 2>&1; then
    corepack pnpm "$@"
  else
    echo "❌ 未找到 pnpm 或 corepack。请先安装 Node.js 18+，或启用 corepack：corepack enable"
    exit 1
  fi
}

# 检查是否有涉及 src/ 的变更，才跑耗时检查
CHANGED=$(git diff --cached --name-only)
CHANGED_EXISTING=$(git diff --cached --name-only --diff-filter=ACMR)

echo "🔍 Pre-commit 检查..."

# 0. docs-first 门控
echo "  → 检查文档同步..."
node scripts/check-docs.mjs --staged
if [ $? -ne 0 ]; then
  echo "❌ 文档检查失败，commit 中止。"
  exit 1
fi

# 1. 架构分层约束
if echo "$CHANGED" | grep -q "packages/calendar/src/"; then
  echo "  → 检查架构分层..."
  node scripts/check-arch.mjs
  if [ $? -ne 0 ]; then
    echo "❌ 架构检查失败，commit 中止。"
    exit 1
  fi
fi

# 2. ESLint（仅校验 staged 的 calendar 代码文件，避免被历史 warning 阻断）
CALENDAR_LINT_FILES=$(echo "$CHANGED_EXISTING" | grep -E "^packages/calendar/.*\.(ts|tsx|js)$" || true)
if [ -n "$CALENDAR_LINT_FILES" ]; then
  echo "  → 运行 staged ESLint..."
  (
    cd packages/calendar || exit 1
    REL_FILES=$(echo "$CALENDAR_LINT_FILES" | sed 's#^packages/calendar/##')
    run_pnpm exec eslint --max-warnings 0 $REL_FILES
  )
fi

# 3. Prettier（仅校验 staged 的可格式化文件）
PRETTIER_FILES=$(echo "$CHANGED_EXISTING" | grep -E "\.(ts|tsx|js|jsx|mjs|cjs|json|md|yml|yaml|css|scss)$" || true)
if [ -n "$PRETTIER_FILES" ]; then
  echo "  → 运行 staged Prettier 检查..."
  run_pnpm exec prettier --check $PRETTIER_FILES
fi

# 4. TypeScript 类型检查（每次提交都执行）
echo "  → TypeScript 类型检查..."
run_pnpm --filter swell-calendar exec tsc --noEmit

# 5. Calendar 测试（每次提交都执行）
echo "  → 运行 Calendar 测试..."
run_pnpm --filter swell-calendar test

echo "✅ 所有检查通过"
exit 0
